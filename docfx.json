{
  "metadata": [
    {
      "src": [
        {
          "files": ["TactileCs.csproj"],
          "src": "."
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/**.md",
          "docs/**/toc.yml",
          "toc.yml",
          "*.md"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "overwrite": [],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": ["default", "modern"],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false,
    "globalMetadata": {
      "_appTitle": "TactileCs API Reference",
      "_appName": "TactileCs",
      "_appFooter": "TactileCs — a .NET 8 port of Craig S. Kaplan's Tactile isohedral tiling library. BSD-3-Clause.",
      "_enableSearch": true
    }
  }
}
